# CryoAnime Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file containing real secrets to version control.

# --- Application ---
# The public URL of your deployed site (used for Open Graph, sitemaps, etc.)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# --- Optional: Analytics ---
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Optional: Feature flags ---
# NEXT_PUBLIC_ENABLE_NSFW=false
